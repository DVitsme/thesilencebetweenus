{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@shadcnblocks": {
      "url": "https://shadcnblocks.com/r/{name}",
      "headers": {
        "Authorization": "Bearer ${SHADCNBLOCKS_API_KEY}"
      }
    },
    "@shadcn-studio": "https://shadcnstudio.com/r/components/new-york-v4/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}",
    "@ss-blocks": "https://shadcnstudio.com/r/blocks/new-york-v4/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}",
    "@ss-components": "https://shadcnstudio.com/r/components/new-york-v4/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}"
  }
}
